  }                                                                                                                                                                                           
  @keyframes fadeUp{0%{opacity:1;transform:translateY(0) scale(1)}100%{opacity:0;transform:translateY(-70px) scale(1.3)}}                                                                     
  .row{display:flex;gap:10px;flex-wrap:wrap;justify-content:center;margin-top:16px}                                                                                                           
  </style>                                                                                                                                                                                    
